# OpenAI API Configuration
# Required: Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
# Optional: Customize OpenAI settings
# OPENAI_MODEL=gpt-4
# OPENAI_TEMPERATURE=0.1

# Redis Configuration (for Celery queue system)
REDIS_URL=redis://localhost:6379/0

# PostgreSQL Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/financial_analyzer
# Or for async: postgresql+asyncpg://user:password@localhost:5432/financial_analyzer

# API Configuration
API_HOST=127.0.0.1
API_PORT=8000

# File Upload Limits
MAX_FILE_SIZE_MB=50

# Celery Configuration
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
